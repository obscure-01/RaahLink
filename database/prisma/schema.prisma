generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  loyaltyTier  String    @default("STANDARD") // STANDARD, SILVER, GOLD, PLATINUM
  loyaltyPoints Int      @default(0)
  bookings     Booking[]
}

model Flight {
  id                 Int       @id @default(autoincrement())
  flightNumber       String    @unique
  origin             String
  destination        String
  departureTime      DateTime
  arrivalTime        DateTime
  economyCapacity    Int
  businessCapacity   Int
  economyCount       Int       @default(0) // tracks current booked
  businessCount      Int       @default(0) // tracks current booked
  basePriceEx        Float     // Economy price
  basePriceBz        Float     // Business price
  bookings           Booking[]
}

model Booking {
  id           Int       @id @default(autoincrement())
  user         User      @relation(fields: [userId], references: [id])
  userId       Int
  flight       Flight    @relation(fields: [flightId], references: [id])
  flightId     Int
  status       String    @default("CONFIRMED") // CONFIRMED, WAITLISTED, CANCELLED
  fareClass    String    // ECONOMY, BUSINESS
  bookingTime  DateTime  @default(now())
}
